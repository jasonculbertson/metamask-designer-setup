{
  "name": "metamask-designer-setup",
  "version": "1.0.0",
  "description": "One-click MetaMask Mobile setup for designers",
  "main": "dist/main.js",
  "scripts": {
    "postinstall": "npx playwright install chromium",
    "prebuild": "node scripts/copy-chromium.js",
    "build": "tsc",
    "start": "npm run build && npx electron .",
    "dist": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.metamask.designer-setup",
    "productName": "MetaMask Designer Setup",
    "copyright": "MetaMask",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "MetaMask Designer Setup",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 400 }
    },
    "files": [
      "dist/**/*",
      "src/index.html",
      "assets/icon.icns"
    ],
    "extraResources": [
      {
        "from": "chromium-bundle",
        "to": "chromium-bundle",
        "filter": ["**/*"]
      }
    ],
    "asar": true
  },
  "dependencies": {
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
