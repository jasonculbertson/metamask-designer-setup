{
  "name": "metamask-designer-setup",
  "version": "1.0.0",
  "description": "One-click MetaMask Mobile setup for designers",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && npx electron .",
    "dist": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.metamask.designer-setup",
    "productName": "MetaMask Designer Setup",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon": "assets/icon.icns"
    },
    "files": ["dist/**/*", "assets/**/*"],
    "extraResources": [
      { "from": "node_modules/playwright", "to": "playwright" }
    ]
  },
  "dependencies": {
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
