{
  "name": "metamask-designer-setup",
  "version": "1.0.3",
  "description": "One-click MetaMask Mobile setup for designers",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && npx electron .",
    "dist": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.metamask.designer-setup",
    "productName": "MetaMask Designer Setup",
    "copyright": "MetaMask",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "notarize": { "teamId": "2WRVG46HV2" }
    },
    "dmg": {
      "title": "MetaMask Designer Setup",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 400 }
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/*.js",
      "src/index.html",
      "assets/icon.icns"
    ],
    "asar": true
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
